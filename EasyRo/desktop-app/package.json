{
  "name": "easyro-desktop",
  "version": "0.0.3",
  "description": "EasyRo - Roblox Studio AI Assistant",
  "main": "src/main/main.js",
  "author": "EasyRo",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --mac --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.easyro.desktop",
    "productName": "EasyRo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.map",
      "!node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "../rojo.exe",
        "to": "rojo.exe"
      },
      {
        "from": "../default.project.json",
        "to": "project/default.project.json"
      },
      {
        "from": "../opencode.json",
        "to": "project/opencode.json"
      },
      {
        "from": "../AGENTS.md",
        "to": "project/AGENTS.md"
      },
      {
        "from": "../src",
        "to": "project/src",
        "filter": ["**/*", "**/.*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "../../assets/logo.ico",
      "artifactName": "${productName}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "../../assets/logo.ico",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EasyRo",
      "deleteAppDataOnUninstall": true,
      "installerLanguages": ["en_US"],
      "multiLanguageInstaller": false,
      "include": "installer-custom.nsh",
      "artifactName": "${productName} Setup.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3"
  }
}
